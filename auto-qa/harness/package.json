{
    "name": "@futarchy-api/replay-harness-server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Server-side scaffold of the Forked Replay Harness (anvil + indexer + api). See PROGRESS.md.",
    "scripts": {
        "phase-status": "node -e \"console.log('Forked Replay Harness — Phase 1 (anvil fork + block clock). See auto-qa/harness/PROGRESS.md');\"",
        "detect": "node scripts/detect-anvil.mjs",
        "detect:indexers": "node scripts/detect-indexers.mjs",
        "fork": "node scripts/start-fork.mjs",
        "smoke": "node --test tests/smoke-fork.test.mjs",
        "smoke:compose": "node --test tests/smoke-compose.test.mjs",
        "smoke:api": "node --test tests/smoke-api-health.test.mjs",
        "smoke:passthrough": "node --test tests/smoke-api-passthrough.test.mjs",
        "smoke:stress": "node --test tests/smoke-multi-spawn.test.mjs",
        "smoke:detect:indexers": "node --test tests/smoke-detect-indexers.test.mjs",
        "smoke:start:indexers": "node --test tests/smoke-start-indexers.test.mjs",
        "smoke:bootstrap": "node --test tests/smoke-bootstrap-start-block.test.mjs",
        "smoke:orchestration": "node --test tests/smoke-indexer-orchestration.test.mjs",
        "smoke:roundtrip": "node --test tests/smoke-indexer-roundtrip.test.mjs",
        "smoke:scenarios": "node --test tests/smoke-scenario-runner.test.mjs",
        "indexers:bootstrap": "node scripts/bootstrap-start-block.mjs",
        "indexers:start": "node scripts/start-indexers.mjs",
        "indexers:stop": "node scripts/start-indexers.mjs --stop",
        "scenarios:dry": "HARNESS_COMPOSE=1 HARNESS_DRY_RUN=1 node orchestrator/scenario-runner.mjs",
        "scenarios:run": "HARNESS_COMPOSE=1 node orchestrator/scenario-runner.mjs",
        "replay": "echo 'TODO Phase 6 — scenario replay runner' && exit 1",
        "test": "node --test 'tests/**/*.test.mjs'"
    },
    "dependencies": {},
    "devDependencies": {}
}
